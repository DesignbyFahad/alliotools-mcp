{
  "name": "alliotools-mcp",
  "version": "2.0.0",
  "description": "Privacy-first MCP server for allio Tools — 94 utilities that run entirely on your machine. Calculators, converters, developer tools, text, date/time, health, and fun tools.",
  "main": "dist/index.js",
  "bin": {
    "alliotools-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/update-tool-count.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "scripts/update-tool-count.js",
    "tools-manifest.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tools",
    "utilities",
    "calculator",
    "converter",
    "privacy",
    "offline",
    "local",
    "no-telemetry"
  ],
  "author": "Allio Tools <hello@allio.tools> (https://allio.tools)",
  "license": "MIT",
  "homepage": "https://allio.tools/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/DesignbyFahad/alliotools-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/DesignbyFahad/alliotools-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "toolCount": 94,
  "toolBreakdown": {
    "calculators": 22,
